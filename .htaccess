# --- /products/ → current pages (old Shopify product pages) ---
RewriteRule ^products/corian.-quartz-by-dupont/?$ /quartz-brands [R=301,L]
RewriteRule ^products/silestone.-by-cosentino/?$ /quartz-brands [R=301,L]
RewriteRule ^products/compac.-technological-quartz/?$ /quartz-brands [R=301,L]
