# --- /collections/ → current pages ---
RewriteRule ^collections/top-quartz-countertop-brands[^/]*/?$ /quartz-brands [R=301,L]
RewriteRule ^collections/all/?$ / [R=301,L]

# --- Catch-all fallbacks for any other old Shopify URLs ---
RewriteRule ^blogs/news/?$ /blog [R=301,L]
RewriteRule ^blogs/news/(.+)/?$ /blog [R=301,L]
RewriteRule ^collections/?$ / [R=301,L]
RewriteRule ^collections/(.+)/?$ / [R=301,L]
RewriteRule ^products/?$ /quartz-brands [R=301,L]
RewriteRule ^products/(.+)/?$ /quartz-brands [R=301,L]
RewriteRule ^pages/(.+)/?$ / [R=301,L]

# ============================================================
# 301 Redirects: Internal broken link fixes
# ============================================================

# Location pages that don't exist yet — redirect to nearest city
RewriteRule ^sunny-isles-beach/?$ /sunny-isles [R=301,L]
RewriteRule ^north-miami-beach/?$ /miami-beach [R=301,L]
RewriteRule ^hallandale-beach/?$ /hollywood [R=301,L]
RewriteRule ^coconut-grove/?$ /coral-gables [R=301,L]
RewriteRule ^south-miami/?$ /miami [R=301,L]
RewriteRule ^pinecrest/?$ /coral-gables [R=301,L]
RewriteRule ^miami-springs/?$ /hialeah [R=301,L]
RewriteRule ^miami-lakes/?$ /hialeah [R=301,L]

# Cambria designs without individual pages
RewriteRule ^cambria/fairbourne/?$ /cambria [R=301,L]
RewriteRule ^cambria/carrick/?$ /cambria [R=301,L]

# Wrong paths
RewriteRule ^tools/quote-calculator/?$ /quote-calculator [R=301,L]
RewriteRule ^tools/color-visualizer/?$ /color-visualizer [R=301,L]
RewriteRule ^bathroom-countertops/?$ /bathroom-vanity-countertops [R=301,L]

# 301 Redirect .html URLs to clean URLs (SEO-friendly)
# Example: /quartz-brands.html redirects to /quartz-brands
RewriteCond %{THE_REQUEST} \s/(.+)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# 301 Redirect .php URLs to clean URLs (SEO-friendly)
# Example: /quartz-brands.php redirects to /quartz-brands
# Skip API and admin folders
RewriteCond %{REQUEST_URI} !^/api/ [NC]
RewriteCond %{REQUEST_URI} !^/admin/ [NC]
RewriteCond %{THE_REQUEST} \s/(.+)\.php[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# Serve .php file for extensionless URLs
# Skip if it's a real file or directory
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
# Check if .php version exists and serve it
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.*)$ $1.php [L]

# Prevent directory listing
Options -Indexes

# Protect sensitive files
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>

# Block access to sensitive file types
<FilesMatch "\.(htaccess|htpasswd|ini|log|sh|sql|bak)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Set proper MIME types
<IfModule mod_mime.c>
    AddType application/javascript .js
    AddType text/css .css
    AddType image/webp .webp
    AddType image/svg+xml .svg
</IfModule>

# Enable compression for better performance
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE text/javascript
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/json
</IfModule>

# Set caching headers for static assets
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
</IfModule>

# Security headers
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
</IfModule>

# Custom error pages
ErrorDocument 404 /404.php
# ErrorDocument 500 /500.php
