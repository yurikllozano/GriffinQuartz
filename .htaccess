# Set default directory index
DirectoryIndex index.php index.html

# Enable mod_rewrite
RewriteEngine On

# Set the base directory
RewriteBase /

# Handle root URL - serve index.php
RewriteRule ^/?$ index.php [L]

# 301 Redirect soflocountertops.com to griffinquartz.com
RewriteCond %{HTTP_HOST} ^(www\.)?soflocountertops\.com$ [NC]
RewriteRule ^(.*)$ https://griffinquartz.com/$1 [R=301,L]

# Redirect www to non-www
RewriteCond %{HTTP_HOST} ^www\.griffinquartz\.com$ [NC]
RewriteRule ^(.*)$ https://griffinquartz.com/$1 [R=301,L]

# Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ============================================================
# 301 Redirects: Old Shopify URLs → Current site
# From Google Search Console data — every URL with traffic
# ============================================================

